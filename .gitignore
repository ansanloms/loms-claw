.env
config.json
coverage/
.claude/settings.local.json
docker/claude-home/*
docker/claude-workspace/*
!docker/claude-workspace/.claude
!docker/claude-workspace/CLAUDE.md
!docker/claude-workspace/memory
!docker/claude-workspace/cron
!docker/claude-workspace/travel
# travel 配下の個別ノート (YYYYMMDD- プレフィックス) は個人履歴なので git 管理しない
docker/claude-workspace/travel/[0-9]*.md
!**/.gitkeep
**/*.kv
**/*.kv-shm
**/*.kv-wal
