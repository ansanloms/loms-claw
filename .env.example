# ===== Discord =====
# Discord bot トークン（必須）
# Developer Portal > Bot > Token で取得
DISCORD_TOKEN=
# 対象ギルド（サーバー）ID（必須）
# 開発者モードを有効にしてサーバー名を右クリック > ID をコピー
GUILD_ID=
# 操作を許可するユーザー ID（必須）
# この ID のユーザーのみが bot を操作できる
AUTHORIZED_USER_ID=
# mention 不要で全メッセージに反応するチャンネル ID（カンマ区切り）
# 未設定の場合、全チャンネルで bot への mention が必要
# 例: 123456789012345678,234567890123456789
# ACTIVE_CHANNEL_IDS=

# ===== Claude Code CLI =====
# エージェントの最大ターン数（デフォルト: 10）
# CLAUDE_MAX_TURNS=10
# verbose ログの有効/無効（デフォルト: true）
# CLAUDE_VERBOSE=true
# プロセスタイムアウト ms（デフォルト: 300000）
# CLAUDE_TIMEOUT=300000
# ツール許可や MCP 設定はワークスペースの
# .claude/settings.json, .mcp.json で管理する

# ===== セッション =====
# セッション永続化ファイルのパス（デフォルト: ./data/sessions.json）
# チャンネル ID と Claude セッション ID の紐付けを保存し、再起動後も --resume で会話を継続する
# SESSION_FILE=./data/sessions.json

# ===== ログ =====
# ログレベル: DEBUG / INFO / WARN / ERROR（デフォルト: INFO）
LOG_LEVEL=INFO

# ===== Docker 専用（compose.yaml から参照） =====
# ワークスペースのホスト側パス（未設定: docker/claude-workspace）
# .claude/, CLAUDE.md, .mcp.json 等がここに存在する
# CLAUDE_WORKSPACE=./claude-workspace
# Claude Code ホームのホスト側パス（未設定: docker/claude-home）
# 認証情報が保存される
# CLAUDE_HOME=./claude-home

# vim:set ft=sh:
