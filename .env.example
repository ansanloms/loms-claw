# ===== Discord =====
# Discord bot トークン（必須）
# Developer Portal > Bot > Token で取得
DISCORD_TOKEN=
# 対象ギルド（サーバー）ID（必須）
# 開発者モードを有効にしてサーバー名を右クリック > ID をコピー
GUILD_ID=
# 操作を許可するユーザー ID（必須）
# この ID のユーザーのみが bot を操作できる
AUTHORIZED_USER_ID=
# mention 不要で全メッセージに反応するチャンネル ID（カンマ区切り）
# 未設定の場合、全チャンネルで bot への mention が必要
# 例: 123456789012345678,234567890123456789
# ACTIVE_CHANNEL_IDS=

# ===== Claude Code CLI =====
# エージェントの最大ターン数（デフォルト: 10）
# CLAUDE_MAX_TURNS=10
# verbose ログの有効/無効（デフォルト: true）
# CLAUDE_VERBOSE=true
# プロセスタイムアウト ms（デフォルト: 300000）
# CLAUDE_TIMEOUT=300000
# ツール許可や MCP 設定はワークスペースの
# .claude/settings.json, .mcp.json で管理する

# ===== ボイスチャンネル =====
# VC 機能の有効/無効（デフォルト: false）
# VOICE_ENABLED=false
# whisper.cpp サーバー URL（STT）
# WHISPER_URL=http://localhost:8178
# TTS サーバー URL（OpenAI 互換、例: voicevox-openai-tts）
# OPENAI_TTS_URL=http://localhost:8000
# TTS API キー（不要な場合は空）
# OPENAI_TTS_API_KEY=
# TTS モデル名（デフォルト: voicevox）
# OPENAI_TTS_MODEL=voicevox
# TTS スピーカー/音声 ID（デフォルト: 1）
# OPENAI_TTS_SPEAKER=1
# TTS 再生速度（デフォルト: 1）
# OPENAI_TTS_SPEED=1
# STT に送る最小発話時間 ms（デフォルト: 500）
# MIN_SPEECH_MS=500
# 発話とみなす最小 RMS 振幅（デフォルト: 200）
# SPEECH_RMS=200
# AI 再生を中断する最小 RMS 振幅（デフォルト: 500）
# INTERRUPT_RMS=500
# 無人 VC からの自動退出タイムアウト ms（-1 で無効、デフォルト: 600000）
# AUTO_LEAVE_MS=600000
# 発話デバウンス待機時間 ms（デフォルト: 500）
# SPEECH_DEBOUNCE_MS=500
# 通知トーンの有効/無効（デフォルト: true）
# NOTIFICATION_TONE=true
# auto-join: false=無効, true=全VC, カンマ区切り=指定VC IDのみ（デフォルト: false）
# AUTO_JOIN_VC=false

# ===== ログ =====
# ログレベル: DEBUG / INFO / WARN / ERROR（デフォルト: INFO）
LOG_LEVEL=INFO

# ===== Docker 専用（compose.yaml から参照） =====
# コンテナのタイムゾーン（IANA 形式、デフォルト: UTC）
# 例: Asia/Tokyo, America/New_York
# TZ=Asia/Tokyo
# ワークスペースのホスト側パス（未設定: docker/claude-workspace）
# .claude/, CLAUDE.md, .mcp.json 等がここに存在する
# CLAUDE_WORKSPACE=./claude-workspace
# Claude Code ホームのホスト側パス（未設定: docker/claude-home）
# 認証情報が保存される
# CLAUDE_HOME=./claude-home

# vim:set ft=sh:
