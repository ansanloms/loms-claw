{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
  "unstable": ["temporal", "kv"],
  "exclude": ["docker/", "coverage/"],
  "fmt": {
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": { "tags": ["recommended"] },
    "plugins": ["jsr:@aireone/deno-lint-curly"]
  },
  "imports": {
    "@anthropic-ai/claude-agent-sdk": "npm:@anthropic-ai/claude-agent-sdk@0.2.114",
    "@discordjs/voice": "npm:@discordjs/voice@0.19.2",
    "hono": "jsr:@hono/hono@4.12.14",
    "@openai/openai": "jsr:@openai/openai@6.34.0",
    "@snazzah/davey": "npm:@snazzah/davey@0.1.11",
    "@std/front-matter": "jsr:@std/front-matter@1.0.9",
    "discord.js": "npm:discord.js@14.26.3",
    "opusscript": "npm:opusscript@0.1.1",
    "@std/assert": "jsr:@std/assert@1.0.19",
    "ajv": "npm:ajv@8.18.0",
    "@std/dotenv": "jsr:@std/dotenv@0.225.6",
    "@std/path": "jsr:@std/path@1.1.4",
    "@std/streams": "jsr:@std/streams@1.0.17"
  },
  "tasks": {
    "start": "deno run --allow-env --allow-ffi --allow-read --allow-write --allow-net --allow-run main.ts",
    "dev": "deno run --allow-env --allow-ffi --allow-read --allow-write --allow-net --allow-run --watch main.ts",
    "test": "deno test --allow-env --allow-ffi --allow-read --allow-write --allow-net --allow-run --parallel --coverage=coverage && deno coverage coverage",
    "check": "deno check **/*.ts",
    "lint": "deno lint && deno fmt --check",
    "fix": "deno lint --fix && deno fmt"
  }
}
